{
  "manifest_version": 3,
  "name": "Skipper for Salesforce",
  "version": "1.0.2",
  "description": "Grounding and guardrails for AI in Salesforce.",
  "permissions": ["activeTab", "scripting", "storage", "unlimitedStorage", "cookies"],
  "host_permissions": [
    "https://*.lightning.force.com/*",
    "https://*.salesforce.com/*",
    "https://*.my.salesforce.com/*",
    "https://*.salesforce-setup.com/*",
    "https://*.my.salesforce-setup.com/*",
    "https://*.force.com/*",
    "https://api.anthropic.com/*",
    "https://api.openai.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://bdfndqbnuganvfdgtvcg.supabase.co/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "action": {
    "default_title": "Skipper for Salesforce",
    "default_popup": "popup.html",
    "default_icon": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" }
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.lightning.force.com/*",
        "https://*.salesforce.com/*",
        "https://*.salesforce-setup.com/*",
        "https://*.my.salesforce-setup.com/*",
        "https://*.force.com/*"
      ],
      "js": ["salesforce-urls.js", "shared.js", "cache-factory.js", "objects.js", "cmdt.js", "flows.js", "apps.js", "labels.js", "permsets.js", "flow-debug.js", "commands.js", "org-glossary.js", "org-glossary-extractors.js", "soql.js", "ask.js", "feedback.js", "markdown.js", "onboarding.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "open-palette": {
      "suggested_key": { "default": "Ctrl+Shift+K", "mac": "Command+Shift+K" },
      "description": "Open Salesforce Navigator"
    }
  },
  "icons": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" }
}
