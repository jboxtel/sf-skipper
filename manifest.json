{
  "manifest_version": 3,
  "name": "Salesforce Commander",
  "version": "1.1.0",
  "description": "Command palette for instant Salesforce Setup navigation",
  "permissions": ["activeTab", "scripting", "storage", "cookies"],
  "host_permissions": [
    "https://*.lightning.force.com/*",
    "https://*.salesforce.com/*",
    "https://*.my.salesforce.com/*",
    "https://*.salesforce-setup.com/*",
    "https://*.force.com/*",
    "https://api.anthropic.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "https://*.lightning.force.com/*",
        "https://*.salesforce.com/*",
        "https://*.salesforce-setup.com/*",
        "https://*.force.com/*"
      ],
      "js": ["salesforce-urls.js", "shared.js", "objects.js", "flows.js", "commands.js", "soql.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "open-palette": {
      "suggested_key": { "default": "Ctrl+Shift+K", "mac": "Command+Shift+K" },
      "description": "Open Salesforce Navigator"
    }
  },
  "icons": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" }
}
